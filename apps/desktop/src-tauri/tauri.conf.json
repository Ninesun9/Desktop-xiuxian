{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktop Companion",
  "version": "0.1.0",
  "identifier": "com.nines.desktopcompanion",
  "build": {
    "beforeDevCommand": "npm run dev -w @desktop-companion/desktop",
    "beforeBuildCommand": "npm run build -w @desktop-companion/desktop",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Desktop Companion",
        "label": "main",
        "width": 276,
        "height": 428,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true
      },
      {
        "title": "桌宠控制台",
        "label": "console",
        "width": 812,
        "height": 688,
        "resizable": true,
        "transparent": false,
        "decorations": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../../Client2/apjpm-5t3s5.ico",
      "../../../Client2/icon.png"
    ]
  }
}
